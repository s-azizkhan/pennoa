{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pennoa",
  "version": "0.1.0",
  "identifier": "app.pennoa",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Pennoa",
        "width": 520,
        "height": 640,
        "minWidth": 420,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Meeting reminders that respect your flow.",
    "longDescription": "Pennoa flies a small airplane across your screen ten and five minutes before each meeting, trailing a banner with the meeting title. Local-only, no accounts, no telemetry.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
